<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Rajagame21</title>
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback" />
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
  <link href="//cdn.jsdelivr.net/npm/@sweetalert2/theme-dark@4/dark.css" rel="stylesheet" />
  <link rel="stylesheet" href="/lte/dist/css/adminlte.min.css" />
  <link rel="stylesheet" href="/css/admin.css" />
  <style>
    .manual-form {
      margin-top: 20px;
      padding: 20px;
      border-radius: 5px;
      box-shadow: 0 0 5px #27ae60;
      margin-bottom: 30px;
    }

    .manual-form button {
      margin-top: 20px;
    }

    .card-header.pending {
      background-color: #f39c12;
      color: white;
    }

    .card-header.completed {
      background-color: #27ae60;
      color: white;
    }

    .table th {
      background-color: #2c3e50;
      color: white;
    }

    #search {
      width: 300px;
      padding: 8px 15px;
      border: 1px solid #ddd;
      border-radius: 5px;
    }
  </style>
</head>

<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../nav') %>
      <div class="content-wrapper">
        <section class="content-header">
          <div class="container-fluid">
            <div class="row mb-2">
              <div class="col-sm-6">
                <h1>Browse Recharge / Deposit Update</h1>
              </div>
            </div>
          </div>
        </section>

        <div class="container-fluid">
          <!-- Manual Deposit Update Form -->
          <div class="manual-form">
            <div class="text-center">
              <label style="font-size: 18px">Manual Deposit Update</label>
            </div>
            <div class="row">
              <div class="col-md-3">
                <label style="color: #27ae60">User Phone Number</label>
                <input type="text" class="form-control" id="user-phone" placeholder="Enter User Phone" />
              </div>
              <div class="col-md-2">
                <label style="color: #27ae60">Deposit Amount</label>
                <input type="number" class="form-control" id="deposit-amount" placeholder="Amount" />
              </div>
              <div class="col-md-3">
                <label style="color: #27ae60">Transaction ID</label>
                <input type="text" class="form-control" id="transaction-id" placeholder="Transaction ID" />
              </div>
              <div class="col-md-2">
                <label style="color: #27ae60">Payment Method</label>
                <select class="form-control" id="payment-method">
                  <option value="UPI">UPI</option>
                  <option value="USDT">USDT</option>
                  <option value="Bank Transfer">Bank Transfer</option>
                  <option value="Manual">Manual</option>
                </select>
              </div>
              <div class="col-md-2">
                <label>&nbsp;</label>
                <button type="button" class="btn btn-success form-control" id="update-deposit">
                  <i class="fa fa-plus"></i> Add Deposit
                </button>
              </div>
            </div>
          </div>

          <!-- Pending Recharge Requests Table -->
          <div class="card">
            <div class="card-header pending">
              <h3 class="card-title">
                <i class="fas fa-clock"></i> Pending Recharge Requests
              </h3>
              <div class="card-tools">
                <button type="button" class="btn btn-tool" data-card-widget="collapse" title="Collapse">
                  <i class="fas fa-minus"></i>
                </button>
              </div>
            </div>
            <div class="card-body p-0" style="overflow-x: auto">
              <table class="table table-striped projects">
                <thead>
                  <tr>
                    <th class="text-center">#</th>
                    <th class="text-center">Account</th>
                    <th class="text-center">Type</th>
                    <th class="text-center">Amount</th>
                    <th class="text-center">Code</th>
                    <th class="text-center">UTR</th>
                    <th class="text-center">Method</th>
                    <th class="text-center">Time</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Accept/Reject</th>
                  </tr>
                </thead>
                <tbody id="pending-list"></tbody>
              </table>
            </div>
          </div>

          <!-- Completed Recharge Records Table -->
          <div class="card">
            <div class="card-header completed">
              <h3 class="card-title">
                <i class="fas fa-check-circle"></i> Completed Recharge Records
              </h3>
              <div class="card-tools">
                <input type="text" id="search" placeholder="Search account..." style="margin-right: 10px" />
                <button type="button" class="btn btn-tool" data-card-widget="collapse" title="Collapse">
                  <i class="fas fa-minus"></i>
                </button>
              </div>
            </div>
            <div class="card-body p-0" style="overflow-x: auto">
              <table class="table table-striped projects">
                <thead>
                  <tr>
                    <th class="text-center">#</th>
                    <th class="text-center">Account</th>
                    <th class="text-center">Type</th>
                    <th class="text-center">Amount</th>
                    <th class="text-center">Code</th>
                    <th class="text-center">UTR</th>
                    <th class="text-center">Time</th>
                    <th class="text-center">Status</th>
                  </tr>
                </thead>
                <tbody id="completed-list"></tbody>
              </table>
            </div>
            <nav aria-label="Page navigation" style="margin-top: 20px; display: flex; justify-content: center">
              <ul class="pagination">
                <li class="page-item previous">
                  <a class="page-link" href="#" tabindex="-1">Previous</a>
                </li>
                <div id="numbers" style="display: flex"></div>
                <li class="page-item next">
                  <a class="page-link" href="#">Next</a>
                </li>
              </ul>
            </nav>
          </div>
        </div>
      </div>
  </div>
  <script src="/plugins/jquery/jquery.min.js"></script>
  <script src="/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/lte/dist/js/adminlte.min.js"></script>
  <script src="/js/admin/admin.js"></script>
  <script src="//cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.js"></script>
  <script>
    function formateT(params) {
      return params < 10 ? "0" + params : params;
    }

    function timerJoin(params = "", addHours = 0) {
      let date = params ? new Date(Number(params)) : new Date();
      date.setHours(date.getHours() + addHours);
      let years = formateT(date.getFullYear());
      let months = formateT(date.getMonth() + 1);
      let days = formateT(date.getDate());
      let hours = date.getHours() % 12;
      hours = hours === 0 ? 12 : hours;
      let ampm = date.getHours() < 12 ? "AM" : "PM";
      let minutes = formateT(date.getMinutes());
      let seconds = formateT(date.getSeconds());
      return (
        years +
        "-" +
        months +
        "-" +
        days +
        " " +
        hours +
        ":" +
        minutes +
        ":" +
        seconds +
        " " +
        ampm
      );
    }

    const PaymentMethodsMap = {
      upi_gateway: "UPI GATEWAY",
      upi_gatewa: "UPI GATEWAY",
      upi_manual: "UPI Manual",
      usdt_manual: "USDT Manual",
      usdt_manua: "USDT Manual",
      wow_pay: "WOW Pay",
      usdt: "USDT",
    };

    // Show pending recharge requests
    function showPendingList(params) {
      if (!params || params.length === 0) {
        $("#pending-list").html(
          '<tr class="text-center"><td colspan="10">No pending recharges...</td></tr>',
        );
        return;
      }
      let html = "";
      params.forEach((data) => {
        html += `<tr class="text-center">
            <td>${data.id}</td>
            <td><b>${data.phone}</b></td>
            <td>${
  data.type === "bank" ? '<b style="color: #3498db">BANKING</b>' : 
  data.type === "usdt_manual" || data.type === "USDT" ? '<b style="color: #f39c12">USDT</b>' : 
  '<b style="color: #a50064">UPI</b>'
}</td>
            <td><b>₹${data.money}</b></td>
            <td style="min-width: 190px;"><b>${data.id_order}</b></td>
            <td style="min-width: 190px;"><b>${data.utr || "-"}</b></td>
            <td style="min-width: 190px;"><b>${PaymentMethodsMap[data.type] || data.type}</b></td>
            <td style="min-width: 190px;"><b>${timerJoin(data.time)}</b></td>
            <td class="project-state"><span class="badge badge-warning">Waiting...</span></td>
            <td class="project-actions text-center" style="min-width: 160px;">
              <a class="btn btn-success btn-sm confirm-btn" href="#" data-id="${data.id}"><i class="fa fa-check"></i></a>
              <a class="btn btn-danger btn-sm delete-btn" href="#" data-id="${data.id}"><i class="fas fa-trash"></i></a>
            </td>
          </tr>`;
      });
      $("#pending-list").html(html);
    }

    // Show completed recharge records
    function showCompletedList(params) {
      if (!params || params.length === 0) {
        $("#completed-list").html(
          '<tr class="text-center"><td colspan="8">No completed recharges...</td></tr>',
        );
        return;
      }
      let html = "";
      params.forEach((data) => {
        html += `<tr class="text-center">
            <td>${data.id}</td>
            <td><b>${data.phone}</b></td>
            <td>${
  data.type === "bank" ? '<b style="color: #3498db">BANKING</b>' : 
  data.type === "usdt_manual" || data.type === "USDT" ? '<b style="color: #f39c12">USDT</b>' : 
  '<b style="color: #a50064">UPI</b>'
}</td>
            <td><b>₹${data.money}</b></td>
            <td style="min-width: 190px;"><b>${data.id_order}</b></td>
            <td style="min-width: 190px;"><b>${data.utr || "-"}</b></td>
            <td style="min-width: 190px;"><b>${timerJoin(data.time)}</b></td>
            <td class="project-state">
              <span class="badge badge-${data.status == 1 ? "success" : "danger"}">${data.status == 1 ? "Success" : "Closed"}</span>
            </td>
          </tr>`;
      });
      $("#completed-list").html(html);
    }

    // Load both pending and completed recharges
    $.ajax({
      type: "POST",
      url: "/api/webapi/admin/recharge",
      dataType: "json",
      success: function (response) {
        showPendingList(response.datas); // Pending requests
        showCompletedList(response.datas2); // Completed records
      },
    });

    // Accept recharge
    $(document).on("click", ".confirm-btn", function (e) {
      e.preventDefault();
      let id = $(this).data("id");
      $.ajax({
        type: "POST",
        url: "/api/webapi/admin/rechargeDuyet",
        data: { id: id, type: "confirm" },
        dataType: "json",
        success: function (response) {
          Swal.fire("Success!", "Recharge accepted successfully!", "success");
          setTimeout(() => location.reload(), 500);
        },
      });
    });

    // Reject recharge
    $(document).on("click", ".delete-btn", function (e) {
      e.preventDefault();
      let id = $(this).data("id");
      Swal.fire({
        title: "Reject Recharge?",
        text: "Are you sure you want to reject this recharge?",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#e74c3c",
        confirmButtonText: "Yes, Reject",
      }).then((result) => {
        if (result.isConfirmed) {
          $.ajax({
            type: "POST",
            url: "/api/webapi/admin/rechargeDuyet",
            data: { id: id, type: "delete" },
            dataType: "json",
            success: function (response) {
              Swal.fire(
                "Rejected!",
                "Recharge rejected successfully!",
                "success",
              );
              setTimeout(() => location.reload(), 500);
            },
          });
        }
      });
    });

    // Search functionality for completed records
    $("#search").on("keyup", function () {
      const query = $(this).val().toLowerCase();
      $("#completed-list tr").each(function () {
        const text = $(this).text().toLowerCase();
        $(this).toggle(text.indexOf(query) > -1);
      });
    });

    // Manual deposit update
    $("#update-deposit").click(function (e) {
      e.preventDefault();
      const phone = $("#user-phone").val();
      const amount = $("#deposit-amount").val();
      const txnId = $("#transaction-id").val();
      const method = $("#payment-method").val();

      if (!phone || !amount) {
        Swal.fire("Error", "Please enter phone number and amount", "error");
        return;
      }

      Swal.fire({
        title: "Confirm Manual Deposit",
        html: `Add ₹${amount} to user ${phone}?`,
        icon: "question",
        showCancelButton: true,
        confirmButtonColor: "#27ae60",
        confirmButtonText: "Yes, Add",
      }).then((result) => {
        if (result.isConfirmed) {
          // TODO: Implement manual deposit API
          Swal.fire(
            "Info",
            "Manual deposit API endpoint to be implemented",
            "info",
          );
        }
      });
    });
  </script>
</body>

</html>