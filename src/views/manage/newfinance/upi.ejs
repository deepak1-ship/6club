<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Rajagame21</title>
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback" />
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="/lte/dist/css/adminlte.min.css" />
  <link rel="stylesheet" href="/css/admin.css" />
  <link href="https://cdn.jsdelivr.net/npm/@sweetalert2/theme-dark@4/dark.css" rel="stylesheet" />
  <style>
    .content-wrapper {
      background: #f4f6f9;
    }

    .page-container {
      max-width: 500px;
      margin: 0 auto;
      padding: 20px;
    }

    .section-title {
      color: #3b82f6;
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 20px;
    }

    .card-section {
      background: #fff;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .card-header-title {
      font-size: 14px;
      font-weight: 600;
      color: #333;
      margin-bottom: 8px;
    }

    .input-label {
      font-size: 12px;
      color: #666;
      margin-bottom: 6px;
      display: block;
    }

    .form-input {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      font-size: 14px;
      margin-bottom: 12px;
      transition: border-color 0.3s ease;
    }

    .form-input:focus {
      outline: none;
      border-color: #3b82f6;
    }

    .btn-primary-custom {
      background: #3b82f6;
      color: #fff;
      border: none;
      padding: 8px 16px;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.3s ease;
    }

    .btn-primary-custom:hover {
      background: #2563eb;
    }

    .radio-list {
      max-height: 200px;
      overflow-y: auto;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      padding: 10px;
      margin-bottom: 12px;
    }

    .radio-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      border-bottom: 1px solid #f0f0f0;
      cursor: pointer;
    }

    .radio-item:last-child {
      border-bottom: none;
    }

    .radio-item input[type="radio"] {
      width: 18px;
      height: 18px;
      accent-color: #3b82f6;
    }

    .radio-item label {
      margin: 0;
      cursor: pointer;
      font-size: 13px;
      color: #333;
      flex: 1;
    }

    .image-radio-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid #f0f0f0;
      cursor: pointer;
    }

    .image-radio-item:last-child {
      border-bottom: none;
    }

    .image-thumbnail {
      width: 40px;
      height: 40px;
      object-fit: cover;
      border-radius: 4px;
      border: 1px solid #e0e0e0;
    }

    .image-name {
      font-size: 13px;
      color: #333;
      flex: 1;
    }

    .file-input-wrapper {
      display: flex;
      gap: 10px;
      margin-bottom: 12px;
    }

    .file-input-wrapper input[type="file"] {
      flex: 1;
    }

    .scroll-indicator {
      text-align: right;
      color: #999;
      font-size: 12px;
      margin-top: -8px;
      margin-bottom: 12px;
    }

    .empty-list {
      text-align: center;
      color: #999;
      padding: 20px;
      font-size: 13px;
    }

    .btn-delete {
      background: #ef4444;
      color: #fff;
      border: none;
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 12px;
      cursor: pointer;
      margin-left: auto;
      flex-shrink: 0;
    }

    .btn-delete:hover {
      background: #dc2626;
    }

    .loading-spinner {
      text-align: center;
      padding: 20px;
      color: #666;
    }
  </style>
</head>

<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../nav') %>
      <div class="content-wrapper">
        <section class="content">
          <div class="page-container">
            <!-- Manage UPI IDs Section -->
            <h2 class="section-title">Manage UPI IDs</h2>

            <div class="card-section">
              <div class="card-header-title">Add UPI ID</div>
              <label class="input-label">UPI ID</label>
              <input type="text" class="form-input" id="new-upi-id" placeholder="e.g. user@bank" />
              <button class="btn-primary-custom" id="add-upi-btn">
                Add UPI ID
              </button>
            </div>

            <div class="card-section">
              <div class="card-header-title">Select Active UPI ID</div>
              <div class="radio-list" id="upi-list">
                <div class="loading-spinner">
                  <i class="fas fa-spinner fa-spin"></i> Loading...
                </div>
              </div>
              <div class="scroll-indicator"><i class="fas fa-sort"></i> Scroll to see more</div>
              <button class="btn-primary-custom" id="save-upi-selection">
                Save Selection
              </button>
            </div>

            <!-- Manage UPI Images Section -->
            <h2 class="section-title" style="margin-top: 30px">
              Manage UPI Images
            </h2>

            <div class="card-section">
              <div class="card-header-title">Upload Image</div>
              <label class="input-label">Select Image (JPG, PNG)</label>
              <div class="file-input-wrapper">
                <input type="file" class="form-input" id="upi-image-file" accept="image/*" style="padding: 8px" />
              </div>
              <button class="btn-primary-custom" id="upload-image-btn">
                Upload Image
              </button>
            </div>

            <div class="card-section">
              <div class="card-header-title">Select Active Image</div>
              <div class="radio-list" id="image-list">
                <div class="loading-spinner">
                  <i class="fas fa-spinner fa-spin"></i> Loading...
                </div>
              </div>
              <div class="scroll-indicator"><i class="fas fa-sort"></i> Scroll to see more</div>
              <button class="btn-primary-custom" id="save-image-selection">
                Save Selection
              </button>
            </div>
          </div>
        </section>
      </div>
  </div>
  <script src="/plugins/jquery/jquery.min.js"></script>
  <script src="/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/lte/dist/js/adminlte.min.js"></script>
  <script src="/js/admin/admin.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.js"></script>
  <script>
    let upiList = [];
    let imageList = [];
    let activeUpiId = null;
    let activeImageId = null;

    $(document).ready(function () {
      loadUPIData();
      loadImageData();
      bindEvents();
    });

    function loadUPIData() {
      $.ajax({
        url: "/api/admin/newfinance/upi/list",
        method: "GET",
        success: function (response) {
          if (response.status && response.data) {
            upiList = response.data;
            activeUpiId = response.activeId;
            renderUPIList();
          } else {
            renderEmptyUPIList();
          }
        },
        error: function () {
          renderEmptyUPIList();
        },
      });
    }

    function loadImageData() {
      $.ajax({
        url: "/api/admin/newfinance/upi/images",
        method: "GET",
        success: function (response) {
          if (response.status && response.data) {
            imageList = response.data;
            activeImageId = response.activeId;
            renderImageList();
          } else {
            renderEmptyImageList();
          }
        },
        error: function () {
          renderEmptyImageList();
        },
      });
    }

    function renderUPIList() {
      const container = $("#upi-list");
      container.empty();

      if (upiList.length === 0) {
        container.html('<div class="empty-list">No UPI IDs added yet</div>');
        return;
      }

      upiList.forEach((upi) => {
        const isActive = upi.id === activeUpiId;
        const item = `
                    <div class="radio-item">
                        <input type="radio" name="active_upi" id="upi_${upi.id}" value="${upi.id}" ${isActive ? "checked" : ""}>
                        <label for="upi_${upi.id}">${upi.upi_id}</label>
                        <button class="btn-delete delete-upi-btn" data-id="${upi.id}" data-upi="${upi.upi_id}"><i class="fas fa-trash"></i></button>
                    </div>
                `;
        container.append(item);
      });
    }

    function renderEmptyUPIList() {
      $("#upi-list").html(
        '<div class="empty-list">No UPI IDs added yet</div>',
      );
    }

    function renderImageList() {
      const container = $("#image-list");
      container.empty();

      if (imageList.length === 0) {
        container.html(
          '<div class="empty-list">No images uploaded yet</div>',
        );
        return;
      }

      imageList.forEach((img) => {
        const isActive = img.id === activeImageId;
        const item = `
                    <div class="image-radio-item">
                        <input type="radio" name="active_image" id="img_${img.id}" value="${img.id}" ${isActive ? "checked" : ""}>
                        <img src="${img.filepath}" alt="QR" class="image-thumbnail" onerror="this.style.display='none'">
                        <label for="img_${img.id}" class="image-name">${img.filename}</label>
                        <button class="btn-delete delete-image-btn" data-id="${img.id}" data-name="${img.filename}"><i class="fas fa-trash"></i></button>
                    </div>
                `;
        container.append(item);
      });
    }

    function renderEmptyImageList() {
      $("#image-list").html(
        '<div class="empty-list">No images uploaded yet</div>',
      );
    }

    function bindEvents() {
      // Add UPI ID
      $("#add-upi-btn").on("click", function () {
        const upiId = $("#new-upi-id").val().trim();
        if (!upiId) {
          Swal.fire("Error", "Please enter a UPI ID", "error");
          return;
        }

        const btn = $(this);
        btn
          .prop("disabled", true)
          .html('<i class="fas fa-spinner fa-spin"></i>');

        $.ajax({
          url: "/api/admin/newfinance/upi/add",
          method: "POST",
          contentType: "application/json",
          data: JSON.stringify({ upi_id: upiId }),
          success: function (response) {
            btn.prop("disabled", false).text("Add UPI ID");
            if (response.status) {
              Swal.fire("Success", response.message, "success");
              $("#new-upi-id").val("");
              loadUPIData();
            } else {
              Swal.fire("Error", response.message, "error");
            }
          },
          error: function () {
            btn.prop("disabled", false).text("Add UPI ID");
            Swal.fire("Error", "Failed to add UPI ID", "error");
          },
        });
      });

      // Save UPI Selection
      $("#save-upi-selection").on("click", function () {
        const selectedUpi = $('input[name="active_upi"]:checked').val();
        if (!selectedUpi) {
          Swal.fire("Error", "Please select a UPI ID", "error");
          return;
        }

        const btn = $(this);
        btn
          .prop("disabled", true)
          .html('<i class="fas fa-spinner fa-spin"></i>');

        $.ajax({
          url: "/api/admin/newfinance/upi/set-active",
          method: "POST",
          contentType: "application/json",
          data: JSON.stringify({ id: parseInt(selectedUpi) }),
          success: function (response) {
            btn.prop("disabled", false).text("Save Selection");
            if (response.status) {
              Swal.fire("Success", response.message, "success");
            } else {
              Swal.fire("Error", response.message, "error");
            }
          },
          error: function () {
            btn.prop("disabled", false).text("Save Selection");
            Swal.fire("Error", "Failed to save selection", "error");
          },
        });
      });

      // Upload Image
      $("#upload-image-btn").on("click", function () {
        const fileInput = $("#upi-image-file")[0];
        if (!fileInput.files || !fileInput.files[0]) {
          Swal.fire("Error", "Please select an image file", "error");
          return;
        }

        const btn = $(this);
        btn
          .prop("disabled", true)
          .html('<i class="fas fa-spinner fa-spin"></i>');

        const formData = new FormData();
        formData.append("image", fileInput.files[0]);

        $.ajax({
          url: "/api/admin/newfinance/upi/upload",
          method: "POST",
          data: formData,
          processData: false,
          contentType: false,
          success: function (response) {
            btn.prop("disabled", false).text("Upload Image");
            if (response.status) {
              Swal.fire("Success", response.message, "success");
              $("#upi-image-file").val("");
              loadImageData();
            } else {
              Swal.fire("Error", response.message, "error");
            }
          },
          error: function () {
            btn.prop("disabled", false).text("Upload Image");
            Swal.fire("Error", "Failed to upload image", "error");
          },
        });
      });

      // Delete UPI ID (event delegation for dynamically rendered rows)
      $("#upi-list").on("click", ".delete-upi-btn", function () {
        const id = $(this).data("id");
        const upiVal = $(this).data("upi");
        Swal.fire({
          title: "Delete UPI ID?",
          text: `"${upiVal}" will be permanently removed.`,
          icon: "warning",
          showCancelButton: true,
          confirmButtonColor: "#ef4444",
          confirmButtonText: "Delete",
        }).then((result) => {
          if (!result.isConfirmed) return;
          $.ajax({
            url: "/api/admin/newfinance/upi/delete",
            method: "POST",
            contentType: "application/json",
            data: JSON.stringify({ id }),
            success: function (response) {
              if (response.status) {
                Swal.fire("Deleted", response.message, "success");
                loadUPIData();
              } else {
                Swal.fire("Error", response.message, "error");
              }
            },
            error: function () {
              Swal.fire("Error", "Failed to delete UPI ID", "error");
            },
          });
        });
      });

      // Delete QR Image (event delegation for dynamically rendered rows)
      $("#image-list").on("click", ".delete-image-btn", function () {
        const id = $(this).data("id");
        const name = $(this).data("name");
        Swal.fire({
          title: "Delete Image?",
          text: `"${name}" will be permanently removed.`,
          icon: "warning",
          showCancelButton: true,
          confirmButtonColor: "#ef4444",
          confirmButtonText: "Delete",
        }).then((result) => {
          if (!result.isConfirmed) return;
          $.ajax({
            url: "/api/admin/newfinance/upi/image/delete",
            method: "POST",
            contentType: "application/json",
            data: JSON.stringify({ id }),
            success: function (response) {
              if (response.status) {
                Swal.fire("Deleted", response.message, "success");
                loadImageData();
              } else {
                Swal.fire("Error", response.message, "error");
              }
            },
            error: function () {
              Swal.fire("Error", "Failed to delete image", "error");
            },
          });
        });
      });

      // Save Image Selection
      $("#save-image-selection").on("click", function () {
        const selectedImage = $('input[name="active_image"]:checked').val();
        if (!selectedImage) {
          Swal.fire("Error", "Please select an image", "error");
          return;
        }

        const btn = $(this);
        btn
          .prop("disabled", true)
          .html('<i class="fas fa-spinner fa-spin"></i>');

        $.ajax({
          url: "/api/admin/newfinance/upi/image/set-active",
          method: "POST",
          contentType: "application/json",
          data: JSON.stringify({ id: parseInt(selectedImage) }),
          success: function (response) {
            btn.prop("disabled", false).text("Save Selection");
            if (response.status) {
              Swal.fire("Success", response.message, "success");
            } else {
              Swal.fire("Error", response.message, "error");
            }
          },
          error: function () {
            btn.prop("disabled", false).text("Save Selection");
            Swal.fire("Error", "Failed to save selection", "error");
          },
        });
      });
    }
  </script>
</body>

</html>