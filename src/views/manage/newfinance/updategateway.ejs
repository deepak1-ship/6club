<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Rajagame21</title>
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback" />
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="/lte/dist/css/adminlte.min.css" />
  <link rel="stylesheet" href="/css/admin.css" />
  <link href="//cdn.jsdelivr.net/npm/@sweetalert2/theme-dark@4/dark.css" rel="stylesheet" />
  <style>
    .content-wrapper {
      background: #f4f6f9;
    }

    .page-container {
      max-width: 500px;
      margin: 0 auto;
      padding: 20px;
    }

    .page-header {
      text-align: center;
      margin-bottom: 30px;
    }

    .page-header h1 {
      font-size: 20px;
      color: #333;
      margin: 0;
    }

    .page-header i {
      color: #f39c12;
      margin-right: 8px;
    }

    .gateway-section {
      background: #fff;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .gateway-title {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 15px;
      font-size: 16px;
      font-weight: 600;
      color: #333;
    }

    .gateway-title i {
      color: #666;
    }

    .option-card {
      border: 1px solid #e0e0e0;
      border-radius: 10px;
      padding: 15px;
      margin-bottom: 10px;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }

    .option-card:hover {
      border-color: #28a745;
      background: #f8fff8;
    }

    .option-card.selected {
      border-color: #28a745;
      background: #f0fff4;
    }

    .option-radio {
      width: 20px;
      height: 20px;
      border: 2px solid #ccc;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .option-card.selected .option-radio {
      border-color: #28a745;
      background: #28a745;
    }

    .option-radio i {
      color: #fff;
      font-size: 10px;
      display: none;
    }

    .option-card.selected .option-radio i {
      display: block;
    }

    .option-content {
      flex: 1;
    }

    .option-label {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      color: #333;
      margin-bottom: 4px;
    }

    .option-label i {
      color: #666;
    }

    .option-path {
      font-size: 12px;
      color: #888;
    }

    .settings-section {
      background: #fff;
      border-radius: 12px;
      padding: 20px;
      margin-top: 30px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .settings-title {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 15px;
      font-size: 16px;
      font-weight: 600;
      color: #333;
    }

    .settings-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 15px;
      border-radius: 8px;
      margin-bottom: 8px;
      font-size: 14px;
    }

    .settings-item.manual {
      background: #e3f2fd;
      color: #1976d2;
    }

    .settings-item.automatic {
      background: #e8f5e9;
      color: #388e3c;
    }

    .settings-item i {
      font-size: 16px;
    }

    .settings-item .path {
      font-size: 11px;
      color: #666;
      margin-left: auto;
    }

    .loading-spinner {
      text-align: center;
      padding: 50px;
      color: #666;
    }

    .save-btn {
      background: #28a745;
      color: #fff;
      border: none;
      padding: 12px 30px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      width: 100%;
      margin-top: 20px;
      transition: background 0.3s ease;
    }

    .save-btn:hover {
      background: #218838;
    }

    .empty-state {
      text-align: center;
      padding: 50px;
      color: #666;
    }
  </style>
</head>

<body class="hold-transition sidebar-mini">
  <div class="wrapper">
    <%- include('../nav') %>
      <div class="content-wrapper">
        <section class="content">
          <div class="page-container">
            <div class="page-header">
              <h1><i class="fas fa-star"></i>Manage Payment Methods</h1>
            </div>

            <div id="loading" class="loading-spinner">
              <i class="fas fa-spinner fa-spin fa-3x"></i>
              <p class="mt-3">Loading gateways...</p>
            </div>

            <div id="gateway-list" style="display: none">
              <!-- Gateway sections will be rendered here -->
            </div>

            <div id="settings-section" class="settings-section" style="display: none">
              <div class="settings-title">
                <i class="fas fa-list"></i> Current Settings
              </div>
              <div id="current-settings">
                <!-- Current settings will be rendered here -->
              </div>
            </div>

            <button class="save-btn" id="save-btn" style="display: none">
              <i class="fas fa-save mr-2"></i>Save Changes
            </button>

            <div id="empty-state" class="empty-state" style="display: none">
              <i class="fas fa-credit-card" style="font-size: 48px; color: #ddd"></i>
              <p class="mt-3">No payment gateways found</p>
              <a href="/admin/manager/newfinance/paymentgateway" class="btn btn-primary">Add Gateway</a>
            </div>
          </div>
        </section>
      </div>
  </div>
  <script src="/plugins/jquery/jquery.min.js"></script>
  <script src="/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/lte/dist/js/adminlte.min.js"></script>
  <script src="/js/admin/admin.js"></script>
  <script src="//cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.js"></script>
  <script>
    let gateways = [];

    $(document).ready(function () {
      loadGateways();
    });

    function loadGateways() {
      $.ajax({
        url: "/api/admin/newfinance/gateways",
        method: "GET",
        success: function (response) {
          $("#loading").hide();

          if (response.status && response.data && response.data.length > 0) {
            gateways = response.data;
            renderGateways();
            renderCurrentSettings();
            $("#gateway-list").show();
            $("#settings-section").show();
            $("#save-btn").show();
          } else {
            $("#empty-state").show();
          }
        },
        error: function () {
          $("#loading").hide();
          $("#empty-state").show();
        },
      });
    }

    function renderGateways() {
      const container = $("#gateway-list");
      container.empty();

      gateways.forEach((gateway, index) => {
        const gatewayType = gateway.gateway_type || "manual";
        const payName = gateway.pay_name || "Gateway " + (index + 1);
        const pathBase = "/pay/" + payName.toLowerCase().replace(/\s+/g, "");

        const section = `
                    <div class="gateway-section" data-id="${gateway.id}">
                        <div class="gateway-title">
                            <i class="fas fa-wallet"></i> ${payName}
                        </div>
                        <div class="option-card ${gatewayType === "automatic" ? "selected" : ""}" data-type="automatic" data-gateway="${gateway.id}">
                            <div class="option-radio">
                                <i class="fas fa-check"></i>
                            </div>
                            <div class="option-content">
                                <div class="option-label">
                                    <i class="fas fa-sync-alt"></i> Automatic
                                </div>
                                <div class="option-path">Path: ${pathBase}_Automatic</div>
                            </div>
                        </div>
                        <div class="option-card ${gatewayType === "manual" ? "selected" : ""}" data-type="manual" data-gateway="${gateway.id}">
                            <div class="option-radio">
                                <i class="fas fa-check"></i>
                            </div>
                            <div class="option-content">
                                <div class="option-label">
                                    <i class="fas fa-hand-paper"></i> Manual
                                </div>
                                <div class="option-path">Path: ${pathBase}_Manual</div>
                            </div>
                        </div>
                    </div>
                `;
        container.append(section);
      });

      bindEvents();
    }

    function renderCurrentSettings() {
      const container = $("#current-settings");
      container.empty();

      gateways.forEach((gateway, index) => {
        const gatewayType = gateway.gateway_type || "manual";
        const payName = gateway.pay_name || "Gateway " + (index + 1);
        const pathBase = "/pay/" + payName.toLowerCase().replace(/\s+/g, "");
        const typeLabel =
          gatewayType.charAt(0).toUpperCase() + gatewayType.slice(1);

        const item = `
                    <div class="settings-item ${gatewayType}" data-id="${gateway.id}">
                        <i class="fas fa-wallet"></i>
                        <span>${payName} (${typeLabel.toUpperCase()})</span>
                        <span class="path">Path: ${pathBase}_${typeLabel}</span>
                    </div>
                `;
        container.append(item);
      });
    }

    function bindEvents() {
      // Option card click
      $(".option-card")
        .off("click")
        .on("click", function () {
          const gatewayId = $(this).data("gateway");
          const type = $(this).data("type");
          const section = $(this).closest(".gateway-section");

          // Update UI
          section.find(".option-card").removeClass("selected");
          $(this).addClass("selected");

          // Update local data
          const gateway = gateways.find((g) => g.id == gatewayId);
          if (gateway) {
            gateway.gateway_type = type;
          }

          // Update current settings
          renderCurrentSettings();
        });

      // Save button click
      $("#save-btn")
        .off("click")
        .on("click", function () {
          saveGateways();
        });
    }

    function saveGateways() {
      const btn = $("#save-btn");
      btn
        .prop("disabled", true)
        .html('<i class="fas fa-spinner fa-spin mr-2"></i>Saving...');

      const updates = gateways.map((gateway) => ({
        id: gateway.id,
        is_active: gateway.is_active,
        gateway_type: gateway.gateway_type || "manual",
      }));

      $.ajax({
        url: "/api/admin/newfinance/gateways/update-status",
        method: "POST",
        contentType: "application/json",
        data: JSON.stringify({ gateways: updates }),
        success: function (response) {
          btn
            .prop("disabled", false)
            .html('<i class="fas fa-save mr-2"></i>Save Changes');
          if (response.status) {
            Swal.fire(
              "Success",
              "Payment methods updated successfully!",
              "success",
            );
          } else {
            Swal.fire(
              "Error",
              response.message || "Failed to update",
              "error",
            );
          }
        },
        error: function () {
          btn
            .prop("disabled", false)
            .html('<i class="fas fa-save mr-2"></i>Save Changes');
          Swal.fire("Error", "Failed to save changes", "error");
        },
      });
    }
  </script>
</body>

</html>