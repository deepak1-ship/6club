    <script>
        let url = window.location.pathname;
        let phones = url.split('/');
        let phone = phones[phones.length - 1];
        $.ajax({
            type: "POST",
            url: "/api/webapi/admin/member/info",
            data: {
                phone: phone,
            },
            dataType: "json",
            success: function (response) {
                // console.log('Full API Response:', response);

                if (response.status === false) return false;
                let user = response.datas[0];

                // User information updates
                $('.profile-username').text(user.name_user);
                $('#telegram').text(response.telegram ? response.telegram.telegram : 'N/A');
                $('#telegram').attr('href', response.telegram ? response.telegram.telegram : '#');
                $('#id_user').text("ID: " + user.id_user);
                $('#money').text(user.money + ".0");
                $('#roses_all').text(user.roses_f + user.roses_f1 + '.0');
                $('#roses_today').text(user.roses_today + '.0');
                $('#invite').text(response.ng_moi ? response.ng_moi.phone : 'N/A');
                $('#daily').text(response.daily);

                $('#f1').text(response.f1 + " member");
                $('#f2').text(response.f2 + " member");
                $('#f3').text(response.f3 + " member");
                $('#f4').text(response.f4 + " member");
                $('#total_mem').text(response.f1 + response.f2 + response.f3 + response.f4);
                $('#ip').text(user.ip_address);
                $('#level').text((user.level == 1) ? 'ADMIN' : (user.level == 2) ? "CTV" : "USER");

                $('#total_money').text((response.total_r[0] && response.total_r[0].total) ? response.total_r[0].total + '.0' : '0.0');
                $('#total_withdraw').text((response.total_w[0] && response.total_w[0].total) ? response.total_w[0].total + '.0' : '0.0');

                // Bank information handling
                // console.log('Bank data:', response.bank_user);

                if (response.bank_user && Array.isArray(response.bank_user) && response.bank_user.length > 0) {
                    let bankData = response.bank_user[0];
                    currentBankData = bankData; // Store for editing
                    // console.log('Updating bank information with:', bankData);

                    // Update account name
                    if (bankData.name_user) {
                        $('#name').text(bankData.name_user).removeClass('tag-danger').addClass('tag-success');
                    }

                    // Update account number
                    if (bankData.stk) {
                        $('#stk').text(bankData.stk);
                    }

                    // Update bank and branch information separately
                    if (bankData.name_bank) {
                        $('#bank_name').text(bankData.name_bank);
                    }

                    if (bankData.chi_nhanh && bankData.chi_nhanh !== '--' && bankData.chi_nhanh !== '0') {
                        $('#branch').text(bankData.chi_nhanh);
                    }

                    // Update time
                    if (bankData.time) {
                        let formattedTime = timerJoin(bankData.time);
                        $('#timeAddBank').text(formattedTime);
                    }

                    // console.log('Bank information updated successfully');
                } else {
                    // console.log('No bank data found, keeping default "No banks added yet" message');
                }
            },
            error: function (xhr, status, error) {
                console.error('AJAX Error:', error);
                console.error('Status:', status);
                console.error('Response:', xhr.responseText);
            }
        });
    </script>

    <!-- Bank Edit Functionality -->
    <script>
        let currentBankData = null;

        // Edit Bank Button Click
        $('#editBankBtn').click(function (e) {
            e.preventDefault();

            if (currentBankData) {
                // Populate modal with current bank data
                $('#edit_name_user').val(currentBankData.name_user || '');
                $('#edit_stk').val(currentBankData.stk || '');
                $('#edit_name_bank').val(currentBankData.name_bank || '');
                $('#edit_chi_nhanh').val(currentBankData.chi_nhanh || '');
                $('#edit_phone').val(phone);
                $('#edit_bank_id').val(currentBankData.id || '');

                $('#editBankModal').modal('show');
            } else {
                alert('No bank information found to edit. Please add bank details first.');
            }
        });

        // Save Bank Changes
        $('#saveBankBtn').click(function () {
            const formData = {
                phone: $('#edit_phone').val(),
                bank_id: $('#edit_bank_id').val(),
                name_user: $('#edit_name_user').val(),
                stk: $('#edit_stk').val(),
                name_bank: $('#edit_name_bank').val(),
                chi_nhanh: $('#edit_chi_nhanh').val()
            };

            // Validate form
            if (!formData.name_user || !formData.stk || !formData.name_bank || !formData.chi_nhanh) {
                alert('Please fill all fields');
                return;
            }

            $.ajax({
                type: "POST",
                url: "/api/webapi/admin/member/updateBank",
                data: formData,
                dataType: "json",
                success: function (response) {
                    if (response.status === true) {
                        alert('Bank information updated successfully!');
                        $('#editBankModal').modal('hide');

                        // Refresh the page to show updated data
                        location.reload();
                    } else {
                        alert('Error updating bank information: ' + (response.message || 'Unknown error'));
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Update Error:', error);
                    alert('Error updating bank information. Please try again.');
                }
            });
        });
    </script>

    <!--Withdraw-->
    <script>
        const RenderWithdraw = (datas) => {
            if (datas.length == 0) {
                $('#list-withdraw').html(`
                    <tr class="text-center">
                    <td colspan="7">no data...</td>
                    </tr>
                `);
                return;
            }
            let html = '';
            datas.map((data) => {
                html +=
                    `
                <tr class="text-center" style="">
                    <td style="color: #e74c3c;font-weight: 600;min-width: 210px">${data.id_order}</td>
                    <td><b style="color: #3498db">${(data.money)}</b></td>
                    <td style="min-width: 210px;"><b>${data.name_bank}</b></td>
                    <td class="project-state"><span class="badge badge-${(data.status == '1' ? 'success' : 'danger')}">${(data.status == '1' ? 'success' : 'closed')}</span></td>
                    <td style="min-width: 210px;"><b>${timerJoin(data.time)}</b></td>
                </tr>
                `;
            });
            $("#list-withdraw").html(html);
        }

        var pageno = 0;
        var limit = 15;
        var page = 1;
        $.ajax({
            type: "POST",
            url: "/admin/member/listWithdraw/<%=phone%>",
            data: {
                typeid: "1",
                pageno: pageno,
                limit: limit,
                language: "vi",
            },
            dataType: "json",
            success: function (response) {
                $('#text-withdraw').text(page + ' / ' + response.page_total);
                if (response.status === true) return RenderWithdraw(response.datas);
            },
        });

        $('#nextWithdraw').click(function (e) {
            pageno += limit;
            e.preventDefault();
            $.ajax({
                type: "POST",
                url: "/admin/member/listWithdraw/<%=phone%>",
                data: {
                    typeid: "1",
                    pageno: pageno,
                    limit: limit,
                    language: "vi",
                },
                dataType: "json",
                success: function (response) {
                    if (response.datas.length == 0) {
                        $('#nextRecharge').addClass('block-click');
                        return pageno -= limit
                    };
                    $('#text-withdraw').text(++page + ' / ' + response.page_total);
                    if (response.status === true) return RenderWithdraw(response.datas);
                }
            });
        });

        $('#previousWithdraw').click(function (e) {
            e.preventDefault();
            $('#nextWithdraw').removeClass('block-click');
            pageno -= limit;
            if (pageno < 0) return pageno = 0;
            $.ajax({
                type: "POST",
                url: "/admin/member/listWithdraw/<%=phone%>",
                data: {
                    typeid: "1",
                    pageno: pageno,
                    limit: limit,
                    language: "vi",
                },
                dataType: "json",
                success: function (response) {
                    $('#text-withdraw').text(--page + ' / ' + response.page_total);
                    if (response.status === true) return RenderWithdraw(response.datas);
                }
            });
        });
    </script>
