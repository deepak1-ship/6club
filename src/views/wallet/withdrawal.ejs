<script>
  const WithdrawalMethodOptions = document.querySelector(
    "#withdrawal_methods",
  );
  const ReloadMoneyAmountButton = document.querySelector(
    "#reload_money_amount_button",
  );
  const SubmitWithdrawButton = document.querySelector("#submit_withdraw_btn");
  let MoneyAmountInput = document.querySelector("#money_amount_input");

  const WithdrawalMethodsMap = {
    USDT_ADDRESS: "USDT_ADDRESS",
    BANK_CARD: "BANK_CARD",
  };

  const userInfoTypes = {
    phoneNumber: "phone_user",
    username: "name_user",
    balance: "money_user",
    userId: "id_user",
    referCode: "code",
    betAmount: "total_bet_amount",
    level: "level",
  };

  let userData = null;
  let AllowedWithdrawAmount = 0;
  let totalBetAmountRemaining = 0;

  const fetchUser = async () => {
    try {
      const response = await axios.post("/api/webapi/check/Info");
      userData = response?.data?.userInfo;
      AllowedWithdrawAmount = response.data.allowedWithdrawAmount;
      totalBetAmountRemaining = response.data.totalBetAmountRemaining;
      console.log("===================", response);
    } catch (error) {
      console.log(error);
    }
  };
  const setUserInfoDisplay = async (idName, userInfoType, prefix) => {
    let display = document.getElementById(idName);
    display.textContent = "Loading...";
    console.log(userData);
    try {
      // if (userData === null) {
      //     const response = await axios.get('/api/webapi/GetUserInfo');
      //     userData = response?.data?.data
      // }

      if (userData === null || userData === undefined) {
        throw Error(
          "Something went wrong while fetching the user wallet balance!",
        );
      }

      display.textContent = prefix
        ? prefix(userData?.[userInfoType])
        : userData?.[userInfoType];
    } catch (error) {
      console.log(error);
    }
  };
  const setUserNeedToBet = (remainingBet) => {
    // console.log(remainingBet);
    const needToBet = document.querySelector("#need_to_bet");

    if (needToBet) {
      needToBet.textContent = remainingBet;
    } else {
      console.error("Element not found");
    }
  };
  const alertMessage = (text) => {
    const msg = document.createElement("div");
    msg.setAttribute("data-v-1dcba851", "");
    msg.className = "message_alert_root";

    const msgContent = document.createElement("div");
    msgContent.setAttribute("data-v-1dcba851", "");
    msgContent.className = "message_alert_text";
    msgContent.style = "";
    msgContent.textContent = text;

    msg.appendChild(msgContent);
    document.body.appendChild(msg);

    setTimeout(() => {
      msgContent.classList.remove("v-enter-active", "v-enter-to");
      msgContent.classList.add("v-leave-active", "v-leave-to");

      setTimeout(() => {
        document.body.removeChild(msg);
      }, 100);
    }, 1000);
  };
  const initBankCard = async () => {
    try {
      const response = await axios({
        method: "GET",
        url: "/api/webapi/withdraw/BANK_CARD",
      });

      if (response?.data?.account?.isAvailable) {
        document.querySelector(
          ".addWithdrawType-top[data-v-ef5c8333]",
        ).style.height = "3.76667rem";
        document.querySelector("#main_account_info_holder").innerHTML = `
                     <div class="account_info_container">
                         <div class="account_info_field">
                             <div class="account_info_field_name">
                                 Bank Name:
                             </div>
                             <div class="account_info_field_value">
                                 ${response?.data?.account?.bankName}
                             </div>
                         </div>
                         <div class="account_info_field">
                             <div class="account_info_field_name">
                                 Recipient's Name:
                             </div>
                             <div class="account_info_field_value">
                                 ${response?.data?.account?.recipientName}
                             </div>
                         </div>
                         <div class="account_info_field">
                             <div class="account_info_field_name">
                                 Account Number:
                             </div>
                             <div class="account_info_field_value">
                                 ${response?.data?.account?.bankAccountNumber}
                             </div>
                         </div>
                          <!-- <div class="account_info_field">
                             <div class="account_info_field_name">
                                 UPI Id:
                             </div>
                             <div class="account_info_field_value">
                                 ${response?.data?.account?.upiId}
                             </div>
                         </div>-->

                         <div class="account_change_info" onclick="handleOpenAddMethod()">
                             Change Bank Card Information
                         </div>
                     </div
                 `;
      } else {
        document.querySelector(
          ".addWithdrawType-top[data-v-ef5c8333]",
        ).style.height = "2.66667rem";
        document.querySelector("#main_account_info_holder").innerHTML = `
                     <img onclick="handleOpenAddMethod()" data-v-ef5c8333="" src="data:image/png;base64,">
                     <span data-v-dc48260d="" id="add_method_type_text">Add a bank account number</span>
                 `;
      }
    } catch (error) {
      console.log(error);
      alertMessage("Something went wrong!");
    }
  };
  const initUSDTAddress = async () => {
    try {
      const response = await axios({
        method: "GET",
        url: "/api/webapi/withdraw/usdt_address",
      });

      if (response?.data?.account?.isAvailable) {
        document.querySelector(
          ".addWithdrawType-top[data-v-ef5c8333]",
        ).style.height = "2.66667rem";
        document.querySelector("#main_account_info_holder").innerHTML = `
                     <div class="account_info_container">
                         <div class="account_info_field">
                             <div class="account_info_field_name">
                                 USDT Address:
                             </div>
                             <div class="account_info_field_value">
                                 ${response?.data?.account?.usdtAddress}
                             </div>
                         </div>
                         <div class="account_info_field">
                             <div class="account_info_field_name">
                                 Address Alias:
                             </div>
                             <div class="account_info_field_value">
                                 ${response?.data?.account?.addressAlias}
                             </div>
                         </div>

                         <div class="account_change_info" onclick="handleOpenAddMethod()">
                             Change USDT Address Information
                         </div>
                     </div
                 `;
      } else {
        document.querySelector(
          ".addWithdrawType-top[data-v-ef5c8333]",
        ).style.height = "2.66667rem";
        document.querySelector("#main_account_info_holder").innerHTML = `
                     <img onclick="handleOpenAddMethod()" data-v-ef5c8333="" src="data:image/png;base64,">
                     <span data-v-dc48260d="" id="add_method_type_text">Add address</span>
            `;
      }
    } catch (error) {
      console.log(error);
      alertMessage("Something went wrong!");
    }
  };
  const handleCheckAndSelectWithdrawalMethod = () => {
    let withdrawalMethodList = Array.from(WithdrawalMethodOptions.children);

    withdrawalMethodList = withdrawalMethodList.filter((item) => {
      return !Array.from(item.classList).includes("disabled");
    });

    let currentWithdrawalMethod = withdrawalMethodList.find((item) => {
      return Array.from(item.classList).includes("select");
    });
    console.log(currentWithdrawalMethod.getAttribute("type"));
    switch (currentWithdrawalMethod.getAttribute("type")) {
      case WithdrawalMethodsMap.BANK_CARD:
        document.querySelector("#currency_indicator").innerHTML = "₹";
        initBankCard();
        break;
      case WithdrawalMethodsMap.USDT_ADDRESS:
        document.querySelector("#currency_indicator").innerHTML = "$";
        initUSDTAddress();
        break;
      default:
        document.querySelector("#currency_indicator").innerHTML = "₹";
        initBankCard();
        break;
    }
  };
  const handleSelectPaymentGateway = (event) => {
    Array.from(WithdrawalMethodOptions.children).forEach((child) => {
      child.classList.remove("select");
      if (
        event.currentTarget.getAttribute("type") ===
        child.getAttribute("type")
      ) {
        child.classList.add("select");
      }
    });

    handleCheckAndSelectWithdrawalMethod();
  };
  const handleNumericInput = (event) => {
    const key = event.keyCode;
    // Only allow numbers to be entered
    if (key < 48 || key > 57) {
      event.preventDefault();
    }
  };
  const handleMoneyAmountInput = (event) => {
    inputMoney = parseInt(MoneyAmountInput.value);
    console.log(inputMoney);
    if (inputMoney >= 110) {
      $("#submit_withdraw_btn")
        .css("background", "linear-gradient(90deg, #3BAF4C 0%, #00D08A 100%)")
        .prop("disabled", false);
    } else {
      $("#submit_withdraw_btn")
        .css(
          "background",
          "linear-gradient(180deg, #cfd1de 0%, #c7c9d9 100%)",
        )
        .prop("disabled", true);
    }
  };
  $("#money_amount_input").on("input", handleMoneyAmountInput);

  const handleOpenAddMethod = () => {
    let withdrawalMethodList = Array.from(WithdrawalMethodOptions.children);

    withdrawalMethodList = withdrawalMethodList.filter((item) => {
      return !Array.from(item.classList).includes("disabled");
    });

    let currentWithdrawalMethod = withdrawalMethodList.find((item) => {
      return Array.from(item.classList).includes("select");
    });

    switch (currentWithdrawalMethod.getAttribute("type")) {
      case WithdrawalMethodsMap.BANK_CARD:
        window.location.href = "/wallet/addBank";
        break;
      case WithdrawalMethodsMap.USDT_ADDRESS:
        window.location.href = "/wallet/addAddress";
        break;
      default:
        window.location.href = "";
        break;
    }
  };
  const handleSubmitWithdrawRequest = async () => {
    try {
      let withdrawalMethodList = Array.from(WithdrawalMethodOptions.children);

      withdrawalMethodList = withdrawalMethodList.filter((item) => {
        return !Array.from(item.classList).includes("disabled");
      });

      let currentWithdrawalMethod = withdrawalMethodList.find((item) => {
        return Array.from(item.classList).includes("select");
      });
      const response = await axios({
        method: "POST",
        url: "/api/webapi/withdraw/create",
        data: {
          amount: parseInt(MoneyAmountInput.value),
          withdrawalMethod: currentWithdrawalMethod.getAttribute("type"),
          AllowedWithdrawAmount,
          totalBetAmountRemaining,
        },
      });
      alertMessage(response.data.message);

      setTimeout(() => {
        window.location.href = "/wallet/withdrawalrecord";
      }, 1200);
    } catch (error) {
      console.log(error);
      alertMessage(error?.response?.data?.message || error);
    }
  };
  // Below code will run on Page Load
  handleCheckAndSelectWithdrawalMethod();
  fetchUser().then(() => {
    setUserInfoDisplay("money_amount_display", userInfoTypes.balance);
    setUserNeedToBet(`₹ ${totalBetAmountRemaining.toFixed(2)}`);
  });
  // --------------------------------

  // Even Listeners
  ReloadMoneyAmountButton.addEventListener("click", () => {
    fetchUser().then(() => {
      setUserInfoDisplay("money_amount_display", userInfoTypes.balance);
    });
  });

  SubmitWithdrawButton.addEventListener("click", handleSubmitWithdrawRequest);

  Array.from(WithdrawalMethodOptions.children).forEach((child) => {
    if (Array.from(child.classList).includes("disabled")) return;
    child.addEventListener("click", handleSelectPaymentGateway);
  });
</script>

</html>