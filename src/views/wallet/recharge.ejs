          </div>
          <div data-v-9e03166f="" class="place-right" onclick="clearAmount()">
            <img data-v-9e03166f="" src="/assets/png/clean-82487515.png" alt="" style="cursor:pointer;" />
          </div>
        </div>

        <div data-v-9e03166f="" class="Recharge__container-rechageBtn" id="deposit_fund_btn">
          Deposit
        </div>
      </div>

      <!-- Instructions -->
      <div data-v-7cba6004="" class="Recharge__container-intro">
        <div data-v-7cba6004="" class="Recharge__container-intro__title">
          <div data-v-7cba6004="" class="img">
            <svg data-v-7cba6004="" class="svg-icon icon-shuoming">
              <use xlink:href="#icon-shuoming"></use>
            </svg>
          </div>
          <p data-v-7cba6004="">Recharge instructions</p>
        </div>
        <div data-v-7cba6004="" class="Recharge__container-intro__lists">
          <div data-v-7cba6004="" class="item">
            <p data-v-7cba6004="">If the transfer time is up, please fill out the deposit form again.</p>
            <p data-v-7cba6004="">The transfer amount must match the order you created, otherwise the money cannot be
              credited successfully.</p>
            <p data-v-7cba6004="">If you transfer the wrong amount, our company will not be responsible for the lost
              amount!</p>
            <p data-v-7cba6004="">Note: do not cancel the deposit order after the money has been transferred.</p>
          </div>
        </div>
