  <style>
    .toast-message {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: rgba(0, 0, 0, 0.8);
      color: white;
      padding: 12px 25px;
      border-radius: 8px;
      z-index: 9999;
      animation: fadeInOut 2s ease-in-out;
    }

    @keyframes fadeInOut {
      0% {
        opacity: 0;
      }

      20% {
        opacity: 1;
      }

      80% {
        opacity: 1;
      }

      100% {
        opacity: 0;
      }
    }

    .Recharge__container-rechageBtn {
      cursor: pointer;
    }

    .Recharge__container-rechageBtn.rechage_active {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
  </style>
