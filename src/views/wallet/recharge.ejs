  <script>
    let gateways = [];
    let selectedGateway = null;
    let userData = null;
    let inputMoney = 0;

    // Toast message
    function showToast(message) {
      const toast = document.createElement('div');
      toast.className = 'toast-message';
      toast.textContent = message;
      document.body.appendChild(toast);
      setTimeout(() => toast.remove(), 2000);
    }

    // Fetch user info
    async function fetchUserInfo() {
      try {
        const response = await axios.get('/api/webapi/GetUserInfo');
        if (response.data && response.data.data) {
          userData = response.data.data;
          document.getElementById('money_amount_display').textContent = userData.money_user || '0.00';
        }
      } catch (error) {
        console.error('Error fetching user info:', error);
        document.getElementById('money_amount_display').textContent = '0.00';
      }
    }

    // Initialize page
    $(document).ready(function () {
      // Fetch user info
      fetchUserInfo();

      // Fetch payment gateways
      $.get("/api/pay/getPayTypeName", function (response) {
        console.log('Gateways:', response);
        if (response.status && response.datas) {
          gateways = response.datas;
          renderGateways();
          if (gateways.length > 0) {
            selectGateway(0);
          }
        }
      });

      // Reload balance button
      $('#reload_money_amount_button').on('click', function () {
        document.getElementById('money_amount_display').textContent = 'Loading...';
        fetchUserInfo();
      });

      // Money input change
      $('#money_amount_input').on('input', handleMoneyInputChange);

      // Deposit button click
      $('#deposit_fund_btn').on('click', handleDeposit);
    });

    function renderGateways() {
      const container = $('#tabcard-container');
      container.empty();

      gateways.forEach((gateway, index) => {
        const paymentType = gateway.payment_info?.type || 'upi';
        let iconSrc = '/assets/png/upi-icon.png';
        if (paymentType === 'usdt_address') {
          iconSrc = 'https://ossimg.Big-Mumadmin888.com/bigmumbai/payNameIcon/payNameIcon_202308241247227g2d.png';
        } else {
          iconSrc = 'https://ossimg.Big-Mumadmin888.com/bigmumbai/payNameIcon/payNameIcon_20240131164642ws73.png';
        }

        const html = `
            <div data-v-4f3d8608="" class="Recharge__container-tabcard__items ${index === 0 ? 'active' : ''}" onclick="selectGateway(${index})" data-index="${index}">
              <div data-v-4f3d8608="" class="centers">
                <div data-v-4f3d8608="" class="Recharge__container-tabcard__top">
                  <img data-v-4f3d8608="" class="img" src="${iconSrc}" alt="" />
                </div>
                <div data-v-4f3d8608="" class="Recharge__container-tabcard__bot">
                  ${gateway.pay_name || 'Gateway ' + (index + 1)}
                </div>
              </div>
            </div>
          `;
        container.append(html);
      });
    }

    function selectGateway(index) {
      selectedGateway = gateways[index];

      // Update active tab
      $('.Recharge__container-tabcard__items').removeClass('active');
      $(`.Recharge__container-tabcard__items[data-index="${index}"]`).addClass('active');

      // Update currency indicator
      if (selectedGateway.payment_info?.type === 'usdt_address') {
        $('#currency_indicator').text('$');
      } else {
        $('#currency_indicator').text('₹');
      }

      // Render recharge type info
      renderRechargeType(selectedGateway);

      // Render recharge amounts
      renderRechargeAmounts(selectedGateway);
    }

    function renderRechargeType(gateway) {
      const container = $('#recharge-types-container');
      container.empty();

      const bonus = gateway.bonus_percent || 0;
      const minPrice = gateway.min_price || 100;
      const maxPrice = gateway.max_price || 50000;
      const paymentType = gateway.payment_info?.type || 'upi_id';

      let typeLabel = 'UPI Payment';
      if (paymentType === 'upi_qr') typeLabel = 'QR Code Payment';
      if (paymentType === 'usdt_address') typeLabel = 'USDT Payment';

      const html = `
          <div data-v-9e03166f="" class="Recharge__content-quickInfo__item item_active">
            <div data-v-9e03166f="" class="other">
              <div data-v-9e03166f="">${gateway.pay_name || typeLabel}</div>
              <div data-v-9e03166f="">Balance: ${minPrice} - ${maxPrice >= 1000 ? (maxPrice / 1000) + 'K' : maxPrice}</div>
              ${bonus > 0 ? `<div data-v-9e03166f="" class="bouns">${bonus}% bonus</div>` : ''}
            </div>
          </div>
        `;
      container.append(html);
    }

    function renderRechargeAmounts(gateway) {
      const container = $('#recharge-amounts-container');
      container.empty();

      // Parse recharge_amounts from gateway (comma-separated string)
      let amounts = [];
      if (gateway.recharge_amounts) {
        amounts = gateway.recharge_amounts.split(',').map(a => parseInt(a.trim())).filter(a => !isNaN(a));
      }

      // Default amounts based on payment type
      if (amounts.length === 0) {
        if (gateway.payment_info?.type === 'usdt_address') {
          amounts = [10, 20, 50, 100, 200, 500];
        } else {
          amounts = [300, 500, 1000, 2000, 5000, 10000];
        }
      }

      const currencySymbol = gateway.payment_info?.type === 'usdt_address' ? '$' : '₹';

      amounts.forEach((amount, idx) => {
        let displayAmount = amount;
        if (amount >= 1000 && gateway.payment_info?.type !== 'usdt_address') {
          displayAmount = (amount / 1000) + 'K';
        }

        const html = `
            <div data-v-9e03166f="" class="Recharge__content-paymoney__money-list__item ${idx === 0 ? 'active' : ''}" onclick="setAmount(${amount}, this)" data-amount="${amount}">
              <div data-v-9e03166f="" class="amount">
                <span data-v-9e03166f="">${currencySymbol}</span>${displayAmount}
              </div>
            </div>
          `;
        container.append(html);
      });

      // Set first amount as default
      if (amounts.length > 0) {
        inputMoney = amounts[0];
        $('#money_amount_input').val(amounts[0]);
        updateDepositButtonState();
      }
    }

    function setAmount(amount, element) {
      inputMoney = amount;
      $('#money_amount_input').val(amount);
      $('.Recharge__content-paymoney__money-list__item').removeClass('active');
      $(element).addClass('active');
      updateDepositButtonState();
    }

    function clearAmount() {
      inputMoney = 0;
      $('#money_amount_input').val('');
      $('.Recharge__content-paymoney__money-list__item').removeClass('active');
      updateDepositButtonState();
    }

    function handleMoneyInputChange() {
      const value = parseInt($('#money_amount_input').val()) || 0;
      inputMoney = value;

      // Update quick amount selection
      $('.Recharge__content-paymoney__money-list__item').each(function () {
        const amt = parseInt($(this).data('amount'));
        if (amt === value) {
          $(this).addClass('active');
        } else {
          $(this).removeClass('active');
        }
      });

      updateDepositButtonState();
    }

    function updateDepositButtonState() {
      const btn = $('#deposit_fund_btn');
      const minPrice = selectedGateway?.min_price || 100;

      if (inputMoney >= minPrice) {
        btn.addClass('rechage_active');
      } else {
        btn.removeClass('rechage_active');
      }
    }

    function handleDeposit() {
      if (!selectedGateway) {
        showToast('Please select a payment gateway');
        return;
      }

      const minPrice = selectedGateway.min_price || 100;
      const maxPrice = selectedGateway.max_price || 50000;

      if (!inputMoney || inputMoney < minPrice) {
        showToast(`Minimum deposit amount is ${selectedGateway.payment_info?.type === 'usdt_address' ? '$' : '₹'}${minPrice}`);
        return;
      }

      if (inputMoney > maxPrice) {
        showToast(`Maximum deposit amount is ${selectedGateway.payment_info?.type === 'usdt_address' ? '$' : '₹'}${maxPrice}`);
        return;
      }

      if (!userData || !userData.id_user) {
        showToast('Please login to continue');
        return;
      }

      // Build gateway payment URL
      const gatewayName = encodeURIComponent(selectedGateway.pay_name || 'Gateway');
      const gatewayId = selectedGateway.id;
      const userId = userData.id_user;
      const amount = inputMoney;

      // Redirect to dynamic payment page
      const paymentUrl = `/pay/${gatewayName}/${gatewayId}/${userId}?amount=${amount}`;
      console.log('Redirecting to:', paymentUrl);
      window.location.href = paymentUrl;
    }
  </script>
</body>

