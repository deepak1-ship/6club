          <div data-v-9e03166f="" class="place-div" id="currency_indicator">₹</div>
          <div data-v-9e03166f="" class="van-cell van-field amount-input" modelmodifiers="[object Object]">
            <div class="van-cell__value van-field__value">
              <div class="van-field__body">
                <input type="tel" inputmode="numeric" id="money_amount_input" class="van-field__control"
                  placeholder="Please enter the amount" autocomplete="new-password" />
