<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.6.7/axios.min.js"
        integrity="sha512-NQfB/bDaB8kaSXF8E77JjhHG5PM6XVRxvHzkZiwl3ddWCEPBa23T76MuWSwAJdMGJnmQqM0VeY9kFszsrBEFrQ=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #f5f5f5;
            color: #1a1a1a;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
        }
        .page-wrap {
            max-width: 480px;
            margin: 0 auto;
            background: #fff;
            min-height: 100vh;
        }
        /* Header */
        .header {
            background: #5C35AD;
            padding: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        .header-title {
            color: #fff;
            font-size: 17px;
            font-weight: 700;
            letter-spacing: 0.5px;
        }
        .header-timer {
            position: absolute;
            right: 16px;
            color: #fff;
            font-size: 14px;
            font-variant-numeric: tabular-nums;
        }
        /* Body */
        .body-content { padding: 20px 16px 32px; }
        /* Amount */
        .amount-label {
            text-align: center;
            font-size: 15px;
            color: #555;
            margin-bottom: 6px;
        }
        .amount-value {
            text-align: center;
            font-size: 36px;
            font-weight: 800;
            color: #5C35AD;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }
        .amount-value .currency { font-size: 22px; }
        .scan-hint {
            text-align: center;
            font-size: 14px;
            color: #555;
            margin-bottom: 18px;
        }
        /* QR */
        .qr-wrap {
            display: flex;
            justify-content: center;
            margin: 4px 0 20px;
        }
        .qr-wrap img {
            width: 170px;
            height: 170px;
            object-fit: contain;
            border: 1px solid #eee;
            border-radius: 6px;
            padding: 6px;
            background: #fff;
        }
        /* UPI / USDT display */
        .address-box {
            background: #f5f5f5;
            border-radius: 10px;
            padding: 14px 16px;
            margin-bottom: 16px;
        }
        .address-box .addr-label {
            font-size: 12px;
            color: #888;
            margin-bottom: 8px;
        }
        .address-box .addr-row {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .address-box .addr-value {
            flex: 1;
            font-family: monospace;
            font-size: 14px;
            font-weight: 600;
            word-break: break-all;
            color: #1a1a1a;
        }
        .btn-copy {
            padding: 8px 18px;
            border: none;
            border-radius: 8px;
            background: #5C35AD;
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            white-space: nowrap;
            flex-shrink: 0;
        }
        .usdt-network-badge {
            display: inline-block;
            background: #28a745;
            color: #fff;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 11px;
            margin-left: 6px;
            vertical-align: middle;
        }
        .usdt-note {
            font-size: 12px;
            color: #888;
            margin-top: 8px;
        }
        /* Section headings */
        .section-title {
            font-size: 15px;
            font-weight: 700;
            color: #1a1a1a;
            margin: 20px 0 12px;
        }
        /* Payment method rows */
        .pay-row {
            display: flex;
            align-items: center;
            background: #fff;
            border: 1px solid #eee;
            border-radius: 12px;
            padding: 12px 14px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: background 0.15s;
        }
        .pay-row:active { background: #f3eeff; }
        .pay-row .pay-icon {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            overflow: hidden;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
        }
        .pay-row .pay-icon img { width: 40px; height: 40px; object-fit: contain; }
        .pay-row .pay-info { flex: 1; }
        .pay-row .pay-name { font-size: 15px; font-weight: 700; color: #1a1a1a; }
        .pay-row .pay-sub { font-size: 12px; font-weight: 600; color: #5C35AD; margin-top: 2px; }
        .pay-row .pay-action { color: #5C35AD; flex-shrink: 0; }
        /* Manual transfer */
        .step-item {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            margin-bottom: 10px;
            font-size: 14px;
            color: #1a1a1a;
            font-weight: 600;
        }
        .step-num { color: #1a1a1a; font-weight: 700; flex-shrink: 0; }
        /* UTR form */
        .utr-section { margin-top: 24px; }
        .utr-header {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 14px;
        }
        .utr-title { font-size: 15px; font-weight: 800; color: #1a1a1a; }
        .utr-guide {
            display: flex;
            align-items: center;
            gap: 3px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 600;
            color: #5C35AD;
        }
        .utr-input-row {
            display: flex;
            align-items: center;
            border: 1.5px solid #ddd;
            border-radius: 12px;
            padding: 6px 14px;
            margin-bottom: 16px;
            background: #fff;
        }
        .utr-input-row .utr-req { color: #e80000; font-weight: 700; font-size: 16px; margin-right: 4px; }
        .utr-input-row .utr-label { font-weight: 700; font-size: 15px; margin-right: 12px; flex-shrink: 0; }
        .utr-input-row input {
            flex: 1;
            border: none;
            font-size: 15px;
            outline: none;
            min-width: 0;
            padding: 6px 0;
            background: transparent;
        }
        .btn-submit {
            width: 100%;
            height: 46px;
            background: #5C35AD;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 700;
            color: #fff;
            cursor: pointer;
            transition: opacity 0.2s;
            margin-bottom: 16px;
        }
        .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }
        /* Warning / tip */
        .warning-text {
            text-align: center;
            color: rgb(220, 38, 38);
            font-size: 14px;
            font-weight: 700;
            margin: 12px 0;
        }
        .tip-text {
            text-align: center;
            color: rgb(220, 38, 38);
            font-size: 13px;
            font-weight: 700;
            margin-top: 14px;
        }
        /* Security badge */
        .security-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
            margin-top: 6px;
        }
        .security-badge span { font-size: 12px; color: #888; font-weight: 300; }
        /* Save QR btn */
        .btn-save-qr {
            display: block;
            margin: 0 auto 16px;
            padding: 6px 20px;
            background: #5C35AD;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
        }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
        .pulse { animation: pulse 1.1s ease-in-out infinite; }
    </style>
</head>

<body>
<div class="page-wrap">

    <!-- Header -->
    <div class="header">
        <span class="header-title">payment</span>
        <span class="header-timer" id="timer_display">05:00</span>
    </div>

    <div class="body-content">

        <!-- Amount -->
        <p class="amount-label">Amount Payable</p>
        <div class="amount-value">
            <% if (payment_type === 'usdt_address') { %>
                <span class="currency">$</span><%= amount %>
            <% } else { %>
                <span class="currency">₹</span><%= amount %>
            <% } %>
        </div>
        <p class="scan-hint">Use Mobile Scan code to pay</p>

        <!-- QR Code -->
        <% if (payment_type === 'upi_qr' && qr_image) { %>
        <div class="qr-wrap">
            <img id="qr_image" src="<%= qr_image %>" alt="QR Code" />
        </div>
        <% } %>

        <!-- UPI ID display -->
        <% if ((payment_type === 'upi_id' || payment_type === 'upi_qr') && upi_id) { %>
        <p class="section-title">Manual transfer</p>
        <div class="step-item">
            <span class="step-num">1.</span>
            <span>Copy the below given UPI</span>
        </div>
        <div class="address-box">
            <div class="addr-row">
                <span class="addr-value"><%= upi_id %></span>
                <button class="btn-copy" onclick="copyToClipboard('<%= upi_id %>', 'UPI ID')">Copy</button>
            </div>
        </div>
        <p class="tip-text">Tip: Dont save the UPI, get new UPI every time.</p>
        <% } %>

        <!-- USDT Address display -->
        <% if (payment_type === 'usdt_address' && usdt_address) { %>
        <p class="section-title">Manual transfer</p>
        <div class="step-item">
            <span class="step-num">1.</span>
            <span>Copy the USDT Address
                <span class="usdt-network-badge"><%= network_type %></span>
            </span>
        </div>
        <div class="address-box">
            <div class="addr-row">
                <span class="addr-value"><%= usdt_address %></span>
                <button class="btn-copy" onclick="copyToClipboard('<%= usdt_address %>', 'USDT Address')">Copy</button>
            </div>
            <p class="usdt-note">Send exactly $<%= amount %> USDT via <%= network_type %> network.</p>
        </div>
        <p class="tip-text">Tip: Always use a new address for each transaction.</p>
        <% } %>

        <!-- Warning -->
        <p class="warning-text">Do not save QR codes for repeated payments, or the funds may not be credited.</p>

        <% if (payment_type === 'upi_qr' && qr_image) { %>
        <button class="btn-save-qr" onclick="saveQRCode()">Save QR</button>
        <% } %>

        <!-- Choose Payment Method -->
        <p class="section-title">Choose a payment method to pay</p>

        <!-- Paytm -->
        <div class="pay-row" onclick="openPaymentApp('paytm')">
            <div class="pay-icon">
                <img src="/assets/png/paytm.png" alt="Paytm" />
            </div>
            <div class="pay-info">
                <div class="pay-name">Paytm</div>
                <div class="pay-sub">Recommended</div>
            </div>
            <div class="pay-action pulse">
                <svg width="26" height="26" viewBox="0 0 36 36" fill="none">
                    <path d="M14 10c0 0 4 3.5 4 8s-4 8-4 8" stroke="#5C35AD" stroke-width="2.5" stroke-linecap="round"/>
                    <circle cx="18" cy="18" r="16" stroke="#5C35AD" stroke-width="1.5" opacity="0.25"/>
                    <path d="M10 26c1-2 3-4 5-5" stroke="#5C35AD" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
            </div>
        </div>

        <!-- PhonePe -->
        <div class="pay-row" onclick="openPaymentApp('phonepe')">
            <div class="pay-icon">
                <img src="/assets/png/phonepe.png" alt="PhonePe" />
            </div>
            <div class="pay-info">
                <div class="pay-name">PhonePe</div>
                <div class="pay-sub">Scan QR to pay</div>
            </div>
            <div class="pay-action pulse">
                <svg width="26" height="26" viewBox="0 0 36 36" fill="none">
                    <path d="M14 10c0 0 4 3.5 4 8s-4 8-4 8" stroke="#5C35AD" stroke-width="2.5" stroke-linecap="round"/>
                    <circle cx="18" cy="18" r="16" stroke="#5C35AD" stroke-width="1.5" opacity="0.25"/>
                    <path d="M10 26c1-2 3-4 5-5" stroke="#5C35AD" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
            </div>
        </div>

        <!-- UTR Form -->
        <div class="utr-section">
            <div class="utr-header">
                <span class="utr-title">Paid? Submit UTR / Ref No</span>
                <div class="utr-guide" onclick="showUTRHelp()">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                        <circle cx="12" cy="12" r="10" stroke="#5C35AD" stroke-width="2"/>
                        <path d="M12 8v4m0 4h.01" stroke="#5C35AD" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                    Guide
                </div>
            </div>
            <div class="utr-input-row">
                <span class="utr-req">*</span>
                <span class="utr-label">UTR</span>
                <input type="text" id="utr_input" placeholder="UTR / UPI Ref No / Transaction ID"
                    maxlength="12" inputmode="numeric" pattern="[0-9]*" />
            </div>
            <button class="btn-submit" id="submit_btn" onclick="submitPayment()">Submit UTR / Ref No</button>
            <div class="security-badge">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                    <path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z"
                        stroke="#4CAF50" stroke-width="2" fill="#4CAF50" fill-opacity="0.15"/>
                    <path d="M9 12l2 2 4-4" stroke="#4CAF50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>This payment is secured by UPI APP Pay</span>
            </div>
        </div>

    </div>
</div>

    <!-- Toast -->
    <div data-v-59df0818="" id="toast"
        style="display: none; position: fixed; top: 0px; width: 100%; height: 100%; z-index: 999999; justify-content: center; align-items: center; padding: 0px;">
        <span data-v-59df0818="" id="toast_text"
            style="height: 40px; line-height: 40px; background-color: rgb(170, 170, 170); color: rgb(255, 255, 255); font-size: 16px; padding: 0px 25px; border-radius: 20px;"></span>
    </div>

    <script>
        const gatewayId = <%= gateway_id %>;
        const userId = '<%= user_id %>';
        const amount = <%= amount %>;

        // Timer
        let timerSeconds = 300;
        const timerDisplay = document.getElementById('timer_display');

        function updateTimer() {
            const mins = Math.floor(timerSeconds / 60);
            const secs = timerSeconds % 60;
            timerDisplay.textContent = String(mins).padStart(2, '0') + ':' + String(secs).padStart(2, '0');
            if (timerSeconds > 0) {
                timerSeconds--;
                setTimeout(updateTimer, 1000);
            } else {
                showToast('Payment session expired. Please try again.');
                setTimeout(() => {
                    window.location.replace('/#/wallet/Recharge');
                }, 2000);
            }
        }
        updateTimer();

        function showToast(message, duration = 2000) {
            const toast = document.getElementById('toast');
            const toastText = document.getElementById('toast_text');
            toastText.textContent = message;
            toast.style.display = 'flex';
            setTimeout(() => { toast.style.display = 'none'; }, duration);
        }

        function copyToClipboard(text, label) {
            navigator.clipboard.writeText(text).then(() => {
                showToast(label + ' copied!');
            }).catch(() => {
                const textArea = document.createElement('textarea');
                textArea.value = text;
                document.body.appendChild(textArea);
                textArea.select();
                document.execCommand('copy');
                document.body.removeChild(textArea);
                showToast(label + ' copied!');
            });
        }

        function openPaymentApp(app) {
            const upiId = '<%= upi_id %>';
            const amt = <%= amount %>;
            let url = '';

            switch (app) {
                case 'paytm':
                    url = `paytmmp://cash_wallet?pa=${upiId}&pn=Payment&am=${amt}&cu=INR`;
                    break;
                case 'phonepe':
                    url = `phonepe://pay?pa=${upiId}&pn=Payment&am=${amt}&cu=INR`;
                    break;
                case 'googlepay':
                    url = `tez://upi/pay?pa=${upiId}&pn=Payment&am=${amt}&cu=INR`;
                    break;
            }

            if (url) {
                const link = document.createElement('a');
                link.href = url;
                link.click();

                // Fallback to generic UPI
                setTimeout(() => {
                    window.location.href = `upi://pay?pa=${upiId}&pn=Payment&am=${amt}&cu=INR`;
                }, 1000);
            }
        }

        function saveQRCode() {
            const img = document.getElementById('qr_image');
            if (img) {
                const link = document.createElement('a');
                link.href = img.src;
                link.download = 'payment_qr.png';
                link.click();
                showToast('QR Code saved!');
            }
        }

        function showUTRHelp() {
            alert(`How to find UTR (Unique Transaction Reference):

1. Open your payment app (PhonePe, Paytm, Google Pay, etc.)
2. Go to Transaction History
3. Find your recent payment transaction
4. Click on the transaction details
5. Look for "Transaction ID", "UTR", "Reference Number"
6. Copy this 12-digit number and paste it below

Note: UTR is usually a 12-digit number that confirms your payment.`);
        }

        async function submitPayment() {
            const utr = document.getElementById('utr_input').value.trim();
            const submitBtn = document.getElementById('submit_btn');

            if (!utr) {
                showToast('Please enter Transaction ID / UTR');
                return;
            }

            if (utr.length < 10) {
                showToast('Transaction ID should be at least 10 digits');
                return;
            }

            submitBtn.disabled = true;
            submitBtn.textContent = 'Submitting...';
            submitBtn.style.opacity = '0.6';

            try {
                const response = await axios.post('/pay/submit', {
                    money: amount,
                    utr: utr,
                    gateway_id: gatewayId,
                    user_id: userId
                });

                if (response.data.status) {
                    showToast('Payment submitted successfully!', 3000);
                    setTimeout(() => {
                        window.location.replace('/#/wallet/Rechargehistory');
                    }, 2000);
                } else {
                    showToast(response.data.message || 'Submission failed');
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Submit UTR / Ref No';
                    submitBtn.style.opacity = '1';
                }
            } catch (error) {
                console.error('Error:', error);
                showToast(error.response?.data?.message || 'Something went wrong');
                submitBtn.disabled = false;
                submitBtn.textContent = 'Submit UTR / Ref No';
                submitBtn.style.opacity = '1';
            }
        }

        // Prevent back navigation
        window.addEventListener('pageshow', function (event) {
            if (event.persisted) {
                window.location.reload();
            }
        });
    </script>
</body>

</html>