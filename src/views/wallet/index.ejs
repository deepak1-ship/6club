<script>
    function alertMess(text, sic, type) {
        if (type == 'success') {
            $('body').append(`<div role="dialog" tabindex="0" class="msg van-popup van-popup--center van-toast van-toast--middle van-toast--success" style="z-index: 2001; display:ne;"><i class="van-badge__wrapper van-icon van-icon-success van-toast__icon"><!----><!----><!----></i><div class="van-toast__text">${text}</div><!----></div>`);
        } else {
            $('body').append(`<div role="dialog" tabindex="0" class="msg van-popup van-popup--center van-toast van-toast--middle van-toast--success" style="z-index: 2001; display:ne;"><i class="van-badge__wrapper van-icon van-icon-fail van-toast__icon"><!----><!----><!----></i><div class="van-toast__text">${text}</div><!----></div>`);
        }
        setTimeout(() => {
            $('.msg').removeClass('v-enter-active v-enter-to');
            $('.msg').addClass('v-leave-active v-leave-to');
            setTimeout(() => {
                $('.msg').remove();
            }
                , 100);
            sic.removeClass('block-click');
        }
            , 1000);
    }
    $(document).ready(function () {

        $.ajax({
            type: "GET",
            url: "/api/webapi/GetUserInfo",
            dataType: "json",
            success: function (response) {
                let user = response.data;
                $('.wallet-user .name').text(user.name_user);
                $('.money').text("₹" + user.money_user);
                $('#tpm').text("₹" + user.third_party_money + ".00");
                $('.box').find('.money').text("₹" + user.third_party_money + ".00")
                $('.box').find('.money').first().text("₹" + user.money_user)

                if (user.third_party_money != 0) {
                    $('#c-0').css('stroke-dasharray', '0px, 3140px');
                    $('#c-1').css('stroke-dasharray', '3140px, 3140px');
                    $('#cp-0').text('0%')
                    $('#cp-1').text('100%')
                    $('.box').css('background', 'linear-gradient(90deg, #72C1FF 0%, #4A77FC 100%)')
                    $('.box').first().css('background', '')
                    $('.box').find('h3, span').css('color', '#fff');
                    $('.box').first().find('h3, span').css('color', '#000');
                }

                if (user.money_user != 0) {
                    $('.box').css('background', '')
                    $('.box').first().css('background', 'linear-gradient(90deg, #f95959 0%, #ff9a8e 100%)')
                    $('#c-0').css('stroke-dasharray', '3140px, 3140px');
                    $('#c-1').css('stroke-dasharray', '0px, 3140px');
                    $('#cp-0').text('100%')
                    $('#cp-1').text('0%')

                    $('.box').find('h3, span').css('color', '#000');
                    $('.box').first().find('h3, span').css('color', '#fff');
                }

                // Display total withdraw and total deposit amounts
                $('.total.total-withdraw').text("₹" + response.totalWithdraw + ".00");
                $('.total.total-deposit').text("₹" + response.totalRecharge + ".00");
            }
        });

        // Set initial values for total withdraw and total deposit
        $('.total.total-withdraw').text("₹0.00");
        $('.total.total-deposit').text("₹0.00");
    });

    $('.recycleBtn').click(() => {
        $('.recycleBtnD button').text('')
        $('.loader').fadeIn();

        $.ajax({
            type: "POST",
            url: "/api/webapi/claim/third_party",
            dataType: "json",
            success: function (response) {
                if (response.status) {
                    let user = response.data;
                    $('.money').text("₹" + user.money + ".00");
                    $('.loader').fadeOut();
                    alertMess('Transfered Successfully', this, 'success')
                    window.location.reload();
                } else {
                    $('.loader').fadeOut();
                    alertMess(response.message, this, 'danger')
                }
                $('.recycleBtnD button').text('Main wallet transfer')
            }
        });
    }
    )
</script>
<script src="/js/client.js"></script>

</html>